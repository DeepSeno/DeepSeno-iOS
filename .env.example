# DeepSeno iOS - release environment template
# Copy this file to .env for local releases.
# In GitHub Actions, the workflow writes this file from repository secrets.

# App Store Connect API key id.
Key ID=your_app_store_connect_key_id

# App Store Connect issuer id.
Issuer ID=your_app_store_connect_issuer_id

# Apple Developer Team ID used for code signing.
Team ID=your_apple_developer_team_id

# Bundle identifier for this app build.
Bundle ID=com.enmooy.deepseno

# Optional relay server base URL, e.g. https://relay.example.com/api/v1
# Leave blank to disable relay mode in open-source builds.
Relay Server Base URL=

# Optional locally, required in GitHub Actions.
# Generate on macOS:
# base64 -i ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8 | tr -d '\n'
Private Key Base64=your_base64_encoded_authkey_p8
